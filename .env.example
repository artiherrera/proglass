# ---------------------------------------------------------------------------
# Shopify Storefront API (required)
# Get the token by installing the official "Headless" app in Shopify Admin.
# The same read-only token is used server-side (build) and client-side (cart).
# ---------------------------------------------------------------------------
SHOPIFY_STORE_DOMAIN=tu-tienda.myshopify.com
SHOPIFY_STOREFRONT_ACCESS_TOKEN=
SHOPIFY_API_VERSION=2025-01

# Public mirror — exposed to the browser for client-side cart mutations.
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=tu-tienda.myshopify.com
NEXT_PUBLIC_SHOPIFY_STOREFRONT_ACCESS_TOKEN=
NEXT_PUBLIC_SHOPIFY_API_VERSION=2025-01

# Canonical site URL (used for metadata, sitemap, JSON-LD).
NEXT_PUBLIC_SITE_URL=https://tudominio.com

# ---------------------------------------------------------------------------
# Optional integrations (leave blank to disable — they become no-ops)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_KLAVIYO_PUBLIC_KEY=
